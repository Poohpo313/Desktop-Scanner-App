{
  "name": "@bukolabs/gateway",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../node_modules/@nestjs/cli/bin/nest.js build",
    "dev": "node ../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start": "node ../node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node ../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:gateway": "node ../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:admin": "cross-env BACKEND_ROLE=admin node ../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:superadmin": "cross-env BACKEND_ROLE=superadmin node ../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:user": "cross-env BACKEND_ROLE=user node ../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/platform-socket.io": "^11.0.12",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.1.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.0.12",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.22",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.3"
  }
}
