{
  "name": "bukolabs-scanner",
  "version": "1.0.0",
  "private": true,
  "description": "Bukolabs.io Desktop Scanner & File Management System",
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "electron": "36.4.0",
    "electron-builder": "25.1.8",
    "@electron/get": "3.1.0",
    "@electron/rebuild": "3.7.1",
    "node-abi": "3.80.0"
  },
  "workspaces": [
    "gateway",
    "Admin",
    "SuperAdmin",
    "Admin/apps/backend",
    "SuperAdmin/apps/backend",
    "User/apps/backend",
    "User/packages/*",
    "User/user-interface-electron"
  ],
  "scripts": {
    "dev:gateway": "node scripts/dev-gateway.cjs",
    "dev:admin-api": "npm run start:dev -w @bukolabs/admin-backend",
    "dev:superadmin-api": "npm run start:dev -w @bukolabs/superadmin-backend",
    "dev:user-api": "npm run start:dev -w @bukolabs/user-backend",
    "dev:admin": "npm run dev:web --workspace=admin-interface-react",
    "dev:superadmin": "npm run dev --workspace=super-admin-interface-react",
    "dev:user": "npm run dev -w user-interface-electron",
    "dev:api": "npm run dev:gateway",
    "setup:db": "powershell -ExecutionPolicy Bypass -File scripts/setup-postgres.ps1 -Seed",
    "setup:db:reset": "powershell -ExecutionPolicy Bypass -File scripts/setup-postgres.ps1 -Seed -Reset",
    "setup:postgres-offline": "powershell -ExecutionPolicy Bypass -File scripts/setup-postgres-offline.ps1 -Seed",
    "setup:postgres-offline:reset": "powershell -ExecutionPolicy Bypass -File scripts/setup-postgres-offline.ps1 -Seed -Reset",
    "setup:all-databases": "npm run setup:db && npm run setup:postgres-offline",
    "test:postgres-online": "powershell -ExecutionPolicy Bypass -File scripts/test-postgres-connection.ps1",
    "test:postgres-offline": "powershell -ExecutionPolicy Bypass -File scripts/test-postgres-offline-connection.ps1",
    "reset:superadmin-pin": "node scripts/reset-superadmin-pin.js",
    "migrate:pending": "powershell -ExecutionPolicy Bypass -File scripts/apply-pending-migrations.ps1",
    "cleanup:keys": "node scripts/cleanup-serial-keys.js",
    "cleanup:data": "node scripts/cleanup-app-data.js",
    "build:user": "powershell -ExecutionPolicy Bypass -File scripts/build-user-exe.ps1",
    "build:user:dir": "powershell -ExecutionPolicy Bypass -File scripts/build-user-exe.ps1 -DirOnly",
    "start:gateway:bg": "powershell -ExecutionPolicy Bypass -File scripts/start-gateway-background.ps1",
    "start:gateway:latest": "powershell -ExecutionPolicy Bypass -File scripts/start-gateway-latest.ps1",
    "stop:gateway-service": "powershell -ExecutionPolicy Bypass -File scripts/stop-gateway-service.ps1",
    "install:gateway-service": "powershell -ExecutionPolicy Bypass -File scripts/install-gateway-service.ps1",
    "open-gateway-firewall": "powershell -ExecutionPolicy Bypass -File scripts/open-gateway-firewall.ps1",
    "uninstall:gateway-service": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-gateway-service.ps1",
    "build": "npm run build -w @bukolabs/gateway && npm run build -w @bukolabs/shared-types",
    "rebuild:gateway": "npm run build -w @bukolabs/gateway",
    "rebuild:gateway-service": "powershell -ExecutionPolicy Bypass -File scripts/install-gateway-service.ps1"
  },
  "author": "Aethera Digital & Syn7rgy",
  "license": "UNLICENSED"
}
